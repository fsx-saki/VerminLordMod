	五相赌斗门: {
		DisplayName: 五相赌斗门
		Tooltip: 黄铜质地门楼，上写五相赌斗门
	}
	金精: {
		DisplayName: 金精
		Tooltip: 一种金属材料，金山牛喜食
	}
	煮运锅: {
		DisplayName: 煮运锅
