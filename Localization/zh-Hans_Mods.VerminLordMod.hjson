		DisplayName: 月毒
		Description: 月毒正在侵蚀你
	}

	Canopybuff: {
		DisplayName: 天蓬蛊
		Description: 天蓬之力削弱了对你的伤害效果
	}

	WaterJiabuff: {
		DisplayName: 水甲
		Description: 遍布全身的水流之力化解了攻击
	}

	YanZhoubuff: {
		DisplayName: 炎胄
		Description: 放心，它烫不到自己
	}

	ThunderShieldbuff: {
		DisplayName: 雷盾
		Description: 你现在是等势体
	}

	FireHeartbuff: {
		DisplayName: 炎心
		Description: 你的心脏中似乎流淌着熔岩
	}

	ReWaterbuff: {
		DisplayName: 背水一战
		Description: 撕裂...形骸...解放
	}

	MuMeibuff: {
		DisplayName: 木魅
		Description: 十年树木，百年树人
	}

	Gratingbuff: {
		DisplayName: 光栅
		Description: 光栅控制中
	}

	YanTongbuff: {
		DisplayName: 炎瞳
		Description: 炎瞳凝视中
	}

	MiZongBuff: {
		DisplayName: 迷踪
		Description: 迷踪阵法生效中
	}

	DefenseMiZongBuff: {
