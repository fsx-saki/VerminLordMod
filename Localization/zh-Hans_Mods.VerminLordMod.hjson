	}

	RiverStream: {
		Tooltip:
			'''
			白家寨独门蛊虫
			使用召唤一道潺潺溪流围绕自身，攻防兼备
			[c/ff0000:发动攻击时额外消耗真元]
			[c/00ff00:食性：细沙]
			[c/d1eeee:天下莫柔弱于水，而攻坚强者莫之能胜。]
			'''
		DisplayName: 溪流蛊
		GuLevel: 转数：{0}
		ControlRate: 炼化进度：{0}
		UsesXQi: "{0} 真元需求"
	}

	MoonlightPro: {
		Tooltip:
			'''
			由两只小光蛊和一只月光蛊合练而成
			[c/1e90ff:甩手一记，脸盆大小的幽蓝月刃飞出，穿透空气，发出呼啸之音。]
			'''
		DisplayName: 月芒蛊
		GuLevel: 转数：{0}
		ControlRate: 炼化进度：{0}
		UsesXQi: "{0} 真元消耗"
	}

	Moonlight: {
		Tooltip:
			'''

			古月一族镇族蛊虫
			[c/00ff00:食性：月兰花瓣]
			[c/00ffff:“淡蓝色的光芒，清澈如水，在家老的手中幽幽闪烁，乍一眼看过去，仿佛学堂家老手中掬着一捧月光。”]
			'''
		DisplayName: 月光蛊
		GuLevel: 转数：{0}
		ControlRate: 炼化进度：{0}
		UsesXQi: "{0} 真元消耗"
	}

	Minilight: {
		Tooltip:
