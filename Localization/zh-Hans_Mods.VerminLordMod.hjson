Configs: {
	VerminLordModConfig: {
		DisplayName: 蛊尊模组设置
		Headers.设置: 设置

		LimitSth: {
			Label: 等级限制
			Tooltip: 限制每转蛊师可以获取的额外血量、力量、防御加成，提升平衡性
		}
	}

	UILayoutConfig: {
		DisplayName: UI布局设置

		PanelLayouts: {
			Label: 面板布局
			Tooltip: ""
		}
	}
	月兰花: {
		DisplayName: 月兰花
		Tooltip: 古月山寨栽培的花卉，花瓣如月牙，蓝粉色，是很多蛊虫的食材。
	}
	青竹酒: {
		DisplayName: 青竹酒
		Tooltip: 一种酒，每坛两块元石，用于喂养酒虫。
	}
	青矛竹: {
		DisplayName: 青矛竹
		Tooltip: 青茅山常见的竹子品种
	}
	影壁: {
		DisplayName: 影壁
		Tooltip: 山壁上形成的影像记录，记录了花酒行者和古月四代族长的恩怨，后异变显示花酒行者传承信息。
	}
	紫金化石: {
		DisplayName: 紫金化石
		Tooltip: 赌石用的石材，内含可能封印的蛊虫，外表紫色金黄。
	}
	猴儿酒: {
		DisplayName: 猴儿酒
		Tooltip: 猴儿酒类属果酒，酒香清醇香甜，入口绵柔，一杯元石计价。
	}
	知心草: {
		DisplayName: 知心草
		Tooltip: 一种草药，可节省元石，但被售卖一空。
	}
	紫金石: {
		DisplayName: 紫金石
		Tooltip: 赌石用的石头，可能开出蛊虫或宝物。
	}
	兽皮地图: {
		DisplayName: 兽皮地图
		Tooltip: 王家祖传的白色兽皮地图，详细记录了青茅山的地形、陷阱位置和野兽分布，是猎人的传家宝。
	}
	野猪獠牙: {
		DisplayName: 野猪獠牙
		Tooltip: 野猪的獠牙，可作为蛊虫食物或炼制材料，也是年中考核的成绩凭证。
	}
	地藏花: {
		DisplayName: 地藏花
		Tooltip: 一种特殊的植物，花中藏有蛊虫，需用黄金花液浸泡。
	}
	生机叶: {
		DisplayName: 生机叶
		Tooltip: 一转治疗蛊虫，由九叶生机草催生而成，可用于治疗伤势，市价五十元石一片。
	}
	苦贝酒: {
		DisplayName: 苦贝酒
		Tooltip: 用百年苦贝的汁液酿制的酒，口感又苦又香。
	}
	百年苦贝: {
		DisplayName: 百年苦贝
		Tooltip: 一种贝壳，能积蓄苦水，百年后苦水变为酒。
	}
	战功榜: {
		DisplayName: 战功榜
		Tooltip: 巨幡，由游字蛊驱动，实时显示各小组战绩排名。
	}
	铭牌: {
		DisplayName: 铭牌
		Tooltip: 三族大比中分发的令牌，收集三十块可晋级。
	}
	青铜面具: {
		DisplayName: 青铜面具
		Tooltip: 方源给夏琳的面具，色彩斑斓，用鱼鳞、鸟羽编织而成。
	}
	棺材: {
		DisplayName: 棺材
		Tooltip: 古月一代沉睡的血红大棺材，浮于血湖中央。
	}
	镇魔塔: {
		DisplayName: 镇魔塔
		Tooltip: 铁家在万程山巅建造的百丈高塔，用于关押魔道蛊师，是正道象征。
	}
	灰骨巨书: {
		DisplayName: 灰骨巨书
		Tooltip: 骨制巨书，记载炼蛊秘方、灰骨才子生平及传承考验。
	}
	铁家令牌: {
		DisplayName: 铁家令牌
		Tooltip: 三王传承中的保命道具，可传送出福地。
	}
	通缉令: {
		DisplayName: 通缉令
		Tooltip: 百家发布的追捕方白二人的文书，消息价一千元石，缉杀价五千八百元石。
	}
	金簪草: {
		DisplayName: 金簪草
		Tooltip: 金家战略物资，用于炼制金蚕蛊的辅料，形态为草类。
	}
	白骨秘方: {
		DisplayName: 白骨秘方
		Tooltip: 一种蛊师传承秘方，包括骨枪蛊、螺旋骨枪蛊等，正常售价约六十万元石。
	}
	星辰石: {
		DisplayName: 星辰石
		Tooltip: 一种顽石，内含星辰系蛊，表面有蓝色荧光。
	}
	紫荆令牌: {
		DisplayName: 紫荆令牌
		Tooltip: 方源拥有的昂贵令牌，可用于进入特定场所或作为代价。
	}
	火炭石: {
		DisplayName: 火炭石
		Tooltip: 火炭山特产矿石，燃烧长久、热量不高、无烟雾，用于商家城燃料。
	}
	骨刺: {
		DisplayName: 骨刺
		Tooltip: 方源使用的远程武器，由骨道生成。
	}
	泥沼蟹: {
		DisplayName: 泥沼蟹
		Tooltip: 巨大如山的荒兽，第六次地灾中出现，拥有强大的甲壳和繁殖能力。后被荡魂山杀死，尸体被小狐仙分解。
	}
	魅蓝电影: {
		DisplayName: 魅蓝电影
		Tooltip: 一种由蓝色闪电构成的荒兽，能攻击天地造成福地漏洞。被方源设计驱除出福地。
	}
	风狼王: {
		DisplayName: 风狼王
		Tooltip: 千兽王级别的风狼首领，速度快、攻击强、防御坚固，被方源收服。
	}
	星屑草: {
		DisplayName: 星屑草
		Tooltip: 星萤虫的食物，生长在云土上，喜阴厌阳。
	}
	仙元石: {
		DisplayName: 仙元石
		Tooltip: 蛊仙交易货币，天庭量产。可快速补充仙元。目前天庭减少发放，导致五域仙元石紧缺。
	}
	气泡鱼: {
		DisplayName: 气泡鱼
		Tooltip: 特殊鱼类，能吞食虫子，在体内培育蛊虫，增加虫群产蛊几率。在五域大战时期价值极高。
	}
	铁壳花: {
		DisplayName: 铁壳花
		Tooltip: 狐仙福地西部移植的植物，形成花海，供养花粉兔。
	}
	马群: {
		DisplayName: 马群
		Tooltip: 马尊控制的马群，规模达五十万，包括马皇、万兽王等。
	}
	夜狼皇: {
		DisplayName: 夜狼皇
		Tooltip: 狼群中的皇者，夜狼的兽皇，媲美五转蛊师战力。方源通过它收编大量夜狼群。
	}
	真绸: {
		DisplayName: 真绸
		Tooltip: 上等丝绸，用于包裹鞋子。
	}
	灰白石板: {
		DisplayName: 灰白石板
		Tooltip: 含有地丘传承信息的赝品石板，方源从其中获得画意蛊和地形图。
	}
	来客令: {
		DisplayName: 来客令
		Tooltip: 进入八十八角真阳楼的令牌，只能使用一次，非黄金血脉者需要此令。
	}
	琉璃楼主令: {
		DisplayName: 琉璃楼主令
		Tooltip: 八十八角真阳楼的通行令牌，通过墨化可增加角数，提升权限，可进入秘藏阁或吞噬其他楼主令。
	}
	铁喙飞鹤: {
		DisplayName: 铁喙飞鹤
		Tooltip: 仙鹤门驯养的鹤群，用于奴道战斗。
	}
	石猴毫毛: {
		DisplayName: 石猴毫毛
		Tooltip: 上古炼蛊材料，用于炼制群力蛊，由石磊重现。
	}
	幽冥水母: {
		DisplayName: 幽冥水母
		Tooltip: 喂养浪迹天涯仙蛊的材料之一。
	}
	深海闪电鳗鱼: {
		DisplayName: 深海闪电鳗鱼
		Tooltip: 喂养浪迹天涯仙蛊的材料之一，产于深海。
	}
	走肉树: {
		DisplayName: 走肉树
		Tooltip: 上古荒植，力道植株，枝条如章鱼触手，能攻击
	}
	黄玉狮子: {
		DisplayName: 黄玉狮子
		Tooltip: 荒兽，大如巨象，褐黄色，浓密鬃毛，沉睡，用于配种或交易。
	}
	黑油: {
		DisplayName: 黑油
		Tooltip: 食道仙材，黑色油状，易于开采，产量大，可炼蛊、延缓仙僵死窍崩解，具有腐蚀性，常被采油蛊师采集。
	}
	真武鲤: {
		DisplayName: 真武鲤
		Tooltip: 黑白相间的鲤鱼，天地灵物，异兽王，能言人语。
	}
	地老木: {
		DisplayName: 地老木
		Tooltip: 一种树木，使用观往蛊可看到往昔景象。
	}
	眠云棺椁: {
		DisplayName: 眠云棺椁
		Tooltip: 由仙道杀招凝成的棺椁，内封蛊仙俘虏。
	}
	九宫鹤: {
		DisplayName: 九宫鹤
		Tooltip: 上古荒兽，与鹤风扬关系亲密。
	}
	天龙完整骨骼: {
		DisplayName: 天龙完整骨骼
		Tooltip: 天龙全身骨骼，炼器或炼蛊材料。
	}
	地煞粉: {
		DisplayName: 地煞粉
		Tooltip: 三十两地煞粉，炼蛊材料。
	}
	天柱风: {
		DisplayName: 天柱风
		Tooltip: 风和材料，用于竞拍。
	}
	赤练金: {
		DisplayName: 赤练金
		Tooltip: 仙材，八百斤。
	}
	法眼血: {
		DisplayName: 法眼血
		Tooltip: 仙材，十五滴。
	}
	正天银: {
		DisplayName: 正天银
		Tooltip: 稀有仙材，六百斤。
	}
	星意: {
		DisplayName: 星意
		Tooltip: 东方长凡死后留下的意志体，拥有本体记忆和部分能力，可操控阵法。
	}
	红枣仙元: {
		DisplayName: 红枣仙元
		Tooltip: 七转蛊仙使用的仙元，色泽或呈红褐色。方源消耗其催动仙蛊。
	}
	方寸山: {
		DisplayName: 方寸山
		Tooltip: 小人族拥有的微型山峰，可移动，蕴含律道仙蛊“小”，能施展大而化小杀招。既是重宝也是居所。
	}
	散文鲤: {
		DisplayName: 散文鲤
		Tooltip: 一种稀有奇鱼，与真武鲤并称文武双鲤。受惊时会化为文气，极难捕捉。东海罕见。
	}
	茅草屋: {
		DisplayName: 茅草屋
		Tooltip: 东方部族的第一重宝，被方源等人无声无息收走，导致东方长凡恐慌。具体功能未明，但能支撑八转攻击片刻。
	}
	裂天粉: {
		DisplayName: 裂天粉
		Tooltip: 雪胡老祖战斗后挥洒的洁白粉末，可将白天裂开，威力惊人。
	}
	血毒棠: {
		DisplayName: 血毒棠
		Tooltip: 地灾中出现的花，从生长到凋零仅十个呼吸，凋谢后化成毒血，污染福地。
	}
	血镰草: {
		DisplayName: 血镰草
		Tooltip: 地灾后新生的野草，形似镰刀，可炼制三转凡蛊。
	}
	赤斧花: {
		DisplayName: 赤斧花
		Tooltip: 地灾后新生的野花，花瓣如斧头，白色但绽放赤红光芒，可炼制三转凡蛊。
	}
	幽火龙蟒: {
		DisplayName: 幽火龙蟒
		Tooltip: 资源，在火炭湖中繁衍，次佳环境是火炭石湖，最佳是碧潭福地的布置。
	}
	长恨蛛: {
		DisplayName: 长恨蛛
		Tooltip: 资源，在狐仙福地北部豢养基地中。
	}
	万里丝廊: {
		DisplayName: 万里丝廊
		Tooltip: 萧家拥有的仙蛊屋，能铺设成巨大丝网，加速货物运输，依赖蜘蛛凡蛊维持运转。
	}
	幻景园: {
		DisplayName: 幻景园
		Tooltip: 天莲派的仙蛊屋，可用于埋伏围困敌人，需要大量仙元催动。
	}
	羽圣城: {
		DisplayName: 羽圣城
		Tooltip: 七转仙蛊屋，外形辉煌圣城，由薄青操纵，曾与方源的惊鸿乱斗台碰撞。
	}
	千年苦贝: {
		DisplayName: 千年苦贝
		Tooltip: 炼仙蛊的佳材，外表漆黑有白色纹路如年轮，罕有。
	}
	地极天罡: {
		DisplayName: 地极天罡
		Tooltip: 由罡气和黑泥组成的仙材，难以处理，需特定杀招。
	}
	孪生冰心: {
		DisplayName: 孪生冰心
		Tooltip: 蓝色心脏形状的珍贵仙材，分为普通冰心和孪生冰心（七转仙材），产自玉壶山。
	}
	刺脊星龙鱼: {
		DisplayName: 刺脊星龙鱼
		Tooltip: 普通龙鱼及六转荒兽龙鱼，肉质应用广泛，可做食料和辅助喂养蛊虫。数量巨大，有近百万条。
	}
	交易令: {
		DisplayName: 交易令
		Tooltip: 萧家发布的贸易伙伴令牌，凭此可享受优惠政策，拓展西漠市场。
	}
	风结草: {
		DisplayName: 风结草
		Tooltip: 太古绿天特有的草笼，形似灯笼，需拆解，解开者可免被兽人吞食。
	}
	仙蛊屋黑牢: {
		DisplayName: 仙蛊屋黑牢
		Tooltip: 仙蛊屋，外形如黑色流星，能撞击、干扰敌人，由黑城操纵。
	}
	星夜黏涎: {
		DisplayName: 星夜黏涎
		Tooltip: 地壳蜗牛分泌的黏涎，采集过程需用星光处理，是方源所需的重要材料。
	}
	斑虎蜜蜂蜂翅: {
		DisplayName: 斑虎蜜蜂蜂翅
		Tooltip: 疑似斑虎蜜蜂的蜂翅碎片，太古荒兽残骸，金道道痕极多，发出道痕光晕，准九转仙材。
	}
	云凰碎片: {
		DisplayName: 云凰碎片
		Tooltip: 太古荒兽云凰的身体碎片，似云似雾，蕴含大量云道道痕，可化为凤凰状白云。
	}
	惊鸿乱斗台: {
		DisplayName: 惊鸿乱斗台
		Tooltip: 一座由红莲蛊仙独创的仙蛊屋，能吸摄封印对手的攻势并反击回去。曾被用于镇压八转蛊仙武斗天王，最后埋藏于南疆无名山峰之下。
	}
	红莲鬼脸: {
		DisplayName: 红莲/鬼脸
		Tooltip: 在光阴长河中出现的鬼脸和红莲，修复了春秋蝉并帮助方源重生。
	}
	万里口蚯: {
		DisplayName: 万里口蚯
		Tooltip: 太古荒兽，断肢重生能力强，存在于地沟。
	}
	万目大明牛: {
		DisplayName: 万目大明牛
		Tooltip: 太古荒兽，八转级数，被剑光杀死，其牛角等为仙材。
	}
	生死鲲鹏: {
		DisplayName: 生死鲲鹏
		Tooltip: 律道太古荒兽，有生和死两种形态，方源获得其相对完整的尸体。
	}
	十绝大阵: {
		DisplayName: 十绝大阵
		Tooltip: 影宗布置的仙阵，用于炼制某只神秘仙蛊，以幽魂魔尊的魂道底蕴和万劫力量为养料。
	}
	凡草屋: {
		DisplayName: 凡草屋
		Tooltip: 影宗的仙蛊屋，回收行动失败，被三茅魔仙传人夺取。
	}
	怨气泥人: {
		DisplayName: 怨气泥人
		Tooltip: 戚灾用怨气、荒兽泥怪尸躯和气道手段制成的泥人怪物，具有荒兽级战力，心智简单。
	}
	太古之光: {
		DisplayName: 太古之光
		Tooltip: 炼制定仙游必需的关键蛊材，来自太古时代的光芒，难以捕捉储藏。
	}
	传承印记: {
		DisplayName: 传承印记
		Tooltip: 大能传承的关键凭证，疑似被刘青玉所得，方源曾试图击溃它。
	}
	黄天碎片: {
		DisplayName: 黄天碎片
		Tooltip: 太古九天之一的黄天碎片，可用于扩张宝黄天。
	}
	板栗牦牛: {
		DisplayName: 板栗牦牛
		Tooltip: 荒兽，毛十二的坐骑，被方源拍入坑中，胆怯而无力。
	}
	流光果: {
		DisplayName: 流光果
		Tooltip: 六转仙材，由浓郁极光凝结而成，颜色多样，需特殊种植。
	}
	斑斓霸王花: {
		DisplayName: 斑斓霸王花
		Tooltip: 七转仙材，慧剑蛊的食料，巨大花朵，覆盖方圆千里，需光照、甜气、珍珠土。
	}
	珍珠土: {
		DisplayName: 珍珠土
		Tooltip: 种植斑斓霸王花所需的土壤材料，价格不贵。
	}
	炎鸿石: {
		DisplayName: 炎鸿石
		Tooltip: 炫光蛊的食料。
	}
	六头大蛇黑血: {
		DisplayName: 六头大蛇黑血
		Tooltip: 招灾蛊的食料，来自荒兽六头大蛇。
	}
	太古墟蝠尸体: {
		DisplayName: 太古墟蝠尸体
		Tooltip: 太古荒兽的尸体，曾在太丘战斗中使用，气息能阻挡其他荒兽。
	}
	巨人草: {
		DisplayName: 巨人草
		Tooltip: 太丘上生长的巨大草类，一棵堪比百年大树，形成原始丛林。
	}
	火虹茶: {
		DisplayName: 火虹茶
		Tooltip: 琅琊地灵喜爱的茶水，红彤彤散光，内含游鱼般的虹光，需一口喝掉才能真正品味。
	}
	金晓大殿: {
		DisplayName: 金晓大殿
		Tooltip: 正道一方的基地悬空大殿，恢弘雄壮。
	}
	缘木: {
		DisplayName: 缘木
		Tooltip: 六转仙材，无根之木，生长于池塘。
	}
	青玉风流: {
		DisplayName: 青玉风流
		Tooltip: 七转仙材，风系珍贵材料。
	}
	霸铜: {
		DisplayName: 霸铜
		Tooltip: 七转仙材，金属类。
	}
	铁冠鹰: {
		DisplayName: 铁冠鹰
		Tooltip: 荒兽，黑家豢养的著名鹰种，大量存在于铁鹰福地。
	}
	合鸣鹰: {
		DisplayName: 合鸣鹰
		Tooltip: 黑家新的鹰种，实则源自乔家的心血，威力强于龙鹰。
	}
	第十三座鹰巢: {
		DisplayName: 第十三座鹰巢
		Tooltip: 黑凡留下的一系列考验和宝藏，包括天晶鹰巢、上极天鹰蛋、血道杀招以及黑凡洞天中的本命真传。
	}
	鸡年兽: {
		DisplayName: 鸡年兽
		Tooltip: 上古年兽的一种形态，体型如山，双翼巨大，羽毛鲜艳，鸡爪锋利。可被年兽召来杀招召唤，喜欢吃年蛊，战力强但不受完全掌控。
	}
	五光山: {
		DisplayName: 五光山
		Tooltip: 光道资源产地，产大量光道凡蛊，被方源挪入至尊仙窍。
	}
	太古上极天鹰: {
		DisplayName: 太古上极天鹰
		Tooltip: 太古荒兽，宇道，八转战力，体型巨大，可比巨鲸，可穿透空间进出洞天和太古九天。方源从黑凡真传中获得幼体，通过宙道杀招催熟。
	}
	苍蓝龙鲸: {
		DisplayName: 苍蓝龙鲸
		Tooltip: 太古传奇荒兽，被乐土仙尊点化，拥有仙窍可修行，体内有龙鲸乐土。
	}
	暗流金钢: {
		DisplayName: 暗流金钢
		Tooltip: 六转仙材，以坚硬著称，被剑蛟龙息轻易切开。
	}
	春梦果树: {
		DisplayName: 春梦果树
		Tooltip: 奇特的梦道植株，存在于梦境中，现实需依附树木。
	}
	角连营: {
		DisplayName: 角连营
		Tooltip: 中洲仙蛊屋，由许多蛊虫组成，包括爱意仙蛊。在逆流河中解体。
	}
	揽雀阁: {
		DisplayName: 揽雀阁
		Tooltip: 仙蛊屋，由万海龙流驾驭，可发万千鸟鸣。
	}
	风满楼: {
		DisplayName: 风满楼
		Tooltip: 仙蛊屋，由碧晨天驾驭，可卷起碧绿风柱。
	}
	附天菌: {
		DisplayName: 附天菌
		Tooltip: 六转仙材，生长在太古九天，单一生长，是安全休整地点。
	}
	逆命祭炼大阵: {
		DisplayName: 逆命祭炼大阵
		Tooltip: 大雪山福地中的阵法，用于炼制鸿运齐天仙蛊，后被子阵影响崩溃。
	}
	光照菌: {
		DisplayName: 光照菌
		Tooltip: 荒植，原为嫩绿，需黑暗环境，方源改良为纯白品种用于光照。
	}
	物品寒玉: {
		DisplayName: 物品:寒玉
		Tooltip: 五转蛊材，含寒玉髓可作六转仙材，是广寒峰的主要资源。
	}
	物品神鹿果: {
		DisplayName: 物品:神鹿果
		Tooltip: 六转仙材，形如婴儿拳头，生长于荒兽挂果麋鹿的鹿角上，用于喂养金刚念仙蛊。
	}
	物品龙鳞土: {
		DisplayName: 物品:龙鳞土
		Tooltip: 凡道蛊材，颗颗结粒，土质坚硬，形似龙鳞，能激发龙鱼繁衍。
	}
	物品龙鱼: {
		DisplayName: 物品:龙鱼
		Tooltip: 一种食道创造的荒兽/普通生物，可用于喂养蛊虫，是宝黄天大宗商品。
	}
	脉轮瓜: {
		DisplayName: 脉轮瓜
		Tooltip: 七转仙材，蕴藏炼道道痕，可用于炼蛊，瓜熟地洞大量豢养，占宝黄天六成市场。
	}
	人祖传: {
		DisplayName: 人祖传
		Tooltip: 蛊师世界第一真传，蕴含人道奥义，多位仙尊魔尊从中获益。
	}
	星宿棋盘: {
		DisplayName: 星宿棋盘
		Tooltip: 仙蛊屋，紫薇仙子所有，可用于推算和支撑星投杀招，若得智慧蛊可升九转。
	}
	混天鹰: {
		DisplayName: 混天鹰
		Tooltip: 鹰类荒兽、上古荒兽，鹰头人身，喜好用骨棒作战。
	}
	追虹鹰: {
		DisplayName: 追虹鹰
		Tooltip: 鹰类荒兽，体型较小，喜欢追逐彩虹虹光，速度较快。
	}
	天晶: {
		DisplayName: 天晶
		Tooltip: 材料，用于催熟上极天鹰，大量消耗。
	}
	玉清滴风小竹楼: {
		DisplayName: 玉清滴风小竹楼
		Tooltip: 八转仙蛊屋，武庸所有，以风道为核心，可移动、分解和修复。
	}
	飞沙阁: {
		DisplayName: 飞沙阁
		Tooltip: 侯家的仙蛊屋，移速极快，擅长在土道环境疾驰。
	}
	海角阁: {
		DisplayName: 海角阁
		Tooltip: 翼家的仙蛊屋，曾被梦境惊吓后退。
	}
	烽火台: {
		DisplayName: 烽火台
		Tooltip: 铁家的仙蛊屋，具有快速传送功能，散布南疆各处。
	}
	太古虎形年兽: {
		DisplayName: 太古虎形年兽
		Tooltip: 光阴长河中的太古年兽，虎形，实力强大，主场优势明显。
	}
	黑白颠倒云: {
		DisplayName: 黑白颠倒云
		Tooltip: 特殊云朵，连通黑天与白天，可让生物随机传送。
	}
	雪莲花精: {
		DisplayName: 雪莲花精
		Tooltip: 七转仙材，形似雪莲花，表面覆盖冰层，蕴含生机与寒意，产自雪人部族。
	}
	铜龙鱼: {
		DisplayName: 铜龙鱼
		Tooltip: 龙鱼改良品种，食道资源，比普通赤红龙鱼更优。
	}
	铁龙鱼: {
		DisplayName: 铁龙鱼
		Tooltip: 龙鱼改良品种，食道资源，比铜龙鱼更优。
	}
	银龙鱼: {
		DisplayName: 银龙鱼
		Tooltip: 龙鱼改良品种，食道资源，比铁龙鱼更优，蕴含浓郁食道道痕。
	}
	金龙鱼: {
		DisplayName: 金龙鱼
		Tooltip: 龙鱼最高改良品种，上古荒兽等级，体小鳞金，充满食道道痕，为龙鱼王者。
	}
	豆神宫: {
		DisplayName: 豆神宫
		Tooltip: 八转仙蛊屋，位于房家大本营，是方源和房家争夺的目标，被方源以因果神树杀招影响。
	}
	落英馆: {
		DisplayName: 落英馆
		Tooltip: 房家七转仙蛊屋，外观如木屋挂满鲜花，能飞行并自行修复。
	}
	无常石: {
		DisplayName: 无常石
		Tooltip: 六转仙材，半黑半白，形成于常年征战之地，可用于炼器或修炼。
	}
	鸡笼犬舍: {
		DisplayName: 鸡笼犬舍
		Tooltip: 房家的仙蛊屋，被房功驾驭用于扫荡万家资源点。
	}
	太古魂核: {
		DisplayName: 太古魂核
		Tooltip: 魂兽死后留下的核心，可用于魂道修行，房家曾向方源提供包括八转太古魂核在内的多种魂核。
	}
	定真树: {
		DisplayName: 定真树
		Tooltip: 太古传奇荒植，具有克制大同风的天赋，历史上曾被元莲仙尊杀死。
	}
	镇魂殿: {
		DisplayName: 镇魂殿
		Tooltip: 八转仙蛊屋，天庭用于囚禁幽魂魔尊的场所。
	}
	饮刃酒: {
		DisplayName: 饮刃酒
		Tooltip: 七转仙材，由蒙屠足下血迹渗透地底结合刀道道痕形成，可助刀道悟道。方源取走少量。
	}
	超级仙阵: {
		DisplayName: 超级仙阵
		Tooltip: 方源设计并改进的防御仙阵，由异人蛊仙操控，可对抗离歌等杀招。
	}
	太古石龙: {
		DisplayName: 太古石龙
		Tooltip: 上古荒兽，全身由石块组成，防御极高，有特殊疗伤手段。
	}
	太古年兽: {
		DisplayName: 太古年兽
		Tooltip: 光阴长河中生存的荒兽级生物，种类多样，如太古年鸡、太古年猴等，可被奴役。
	}
	太宇寺: {
		DisplayName: 太宇寺
		Tooltip: 池家八转仙蛊屋，排名天下第九，拥有转宇寰空杀招。
	}
	今古亭: {
		DisplayName: 今古亭
		Tooltip: 七转宙道仙蛊屋，凉亭状，擅长在光阴长河中侦查和操控水流。
	}
	恒舟: {
		DisplayName: 恒舟
		Tooltip: 天庭宙道仙蛊屋，楼船模样，速度较快，支援今古亭但未能及时。
	}
	仙蛊屋雏形: {
		DisplayName: 仙蛊屋雏形
		Tooltip: 方源自创的仙蛊屋雏形，以宙道仙蛊为主，擅长隐匿，在石莲岛被威猛老者摧毁。
	}
	年华池: {
		DisplayName: 年华池
		Tooltip: 至尊仙窍内的特殊建筑，沟通光阴支流，用于拘禁和驯化太古年兽。
	}
	功德方尖碑: {
		DisplayName: 功德方尖碑
		Tooltip: 八转仙蛊屋，位于龙鲸乐土，发布任务并给予功德奖励，可兑换仙材、名号等。
	}
	水核: {
		DisplayName: 水核
		Tooltip: 水道仙材，是道兽死后留下的核心之一。
	}
	巨音贝: {
		DisplayName: 巨音贝
		Tooltip: 荒兽巨音贝死后留下的贝壳，具有音道道痕，可作为舞台扩大声音。
	}
	白荔仙元: {
		DisplayName: 白荔仙元
		Tooltip: 八转蛊仙独有的仙元，方源通过仙窍自产。
	}
	龙宫: {
		DisplayName: 龙宫
		Tooltip: 八转仙蛊屋，内含神秘梦道仙蛊，外形如宫殿，拥有攻伐防护威能，行驶在东海高空，引发八转争夺。
	}
	劫运坛: {
		DisplayName: 劫运坛
		Tooltip: 八转仙蛊屋，巨阳仙尊所创，被冰塞川操纵，曾附着无极魔尊的杀招。
	}
	中央大殿: {
		DisplayName: 中央大殿
		Tooltip: 天庭宫殿的中枢，被劫运坛撞毁。
	}
	一缺抱憾亭: {
		DisplayName: 一缺抱憾亭
		Tooltip: 八转仙蛊屋，位于星驰山顶峰，星宿仙尊与无极魔尊对弈之地。
	}
	炼道大阵: {
		DisplayName: 炼道大阵
		Tooltip: 天庭布置用于修复宿命蛊的大阵，有袁琼都主持。
	}
	针灸树: {
		DisplayName: 针灸树
		Tooltip: 一种特殊的树木，栽种在天露绿洲外围，内含针灸蛊，用于协防。
	}
	天露: {
		DisplayName: 天露
		Tooltip: 八转仙材，透明水滴状，由黑白水每天面对苍穹昼夜轮转而凝聚，是天露绿洲的核心产物。
	}
	万年斗飞车: {
		DisplayName: 万年斗飞车
		Tooltip: 八转仙蛊屋，方源所用，具备多种杀招如破晓剑、激流勇进、万年围猎。
	}
	珠线水: {
		DisplayName: 珠线水
		Tooltip: 八转水道仙材，太古水蜘蛛涎水凝聚。
	}
	五相赌斗门: {
		DisplayName: 五相赌斗门
		Tooltip: 黄铜质地门楼，上写五相赌斗门
	}
	金精: {
		DisplayName: 金精
		Tooltip: 一种金属材料，金山牛喜食
	}
	煮运锅: {
		DisplayName: 煮运锅
		Tooltip: 七转仙蛊屋（煮运锅），大如水盆，浑身金黄作色，笼罩一层洁白光晕，用于煮运、改变气运。
	}
	小箭尾雕: {
		DisplayName: 小箭尾雕
		Tooltip: 从荒兽蛋中孵化出的仙兽小雕，认战部渡为至亲
	}
	松鹤亭: {
		DisplayName: 松鹤亭
		Tooltip: 中洲仙鹤门的仙蛊屋，被方源埋伏吞噬，后由龙公送出战场。
	}
	六声茶: {
		DisplayName: 六声茶
		Tooltip: 沈家名茶，共有六杯，每杯有独特口感与功效。
	}
	军团蚁: {
		DisplayName: 军团蚁
		Tooltip: 绿蚁居士创造的物种，适合奴道蛊仙使用，通过蚁穴蛊孵化。
	}
	万象宫殿: {
		DisplayName: 万象宫殿
		Tooltip: 仙蛊屋，可以变作世间万物，内部有雕像，千变老祖利用其化身假扮自己。
	}
	刹那台: {
		DisplayName: 刹那台
		Tooltip: 八转宙道仙蛊屋，具有瞬移能力（刹那挪移），由顾六如驾驭。
	}
	旱魃炎: {
		DisplayName: 旱魃炎
		Tooltip: 八转旱魃仙僵的火焰，死寂炽热，可配合旱魃仙僵延寿法使用。
	}
	鬼嘤音: {
		DisplayName: 鬼嘤音
		Tooltip: 七转音道仙材，储存在小音贝中，可影响心神。
	}
	日月观: {
		DisplayName: 日月观
		Tooltip: 灵缘斋的宙道仙蛊屋，七转层次，在光阴长河战役中被毁。
	}
	涛声依旧: {
		DisplayName: 涛声依旧
		Tooltip: 七转音道仙材，沈家特产，海螺状荒兽，内含经年环响的涛声。
	}
	诛魔榜: {
		DisplayName: 诛魔榜
		Tooltip: 八转仙蛊屋，外表为朱红墓碑，榜文游动，由古月方正和秦鼎菱操控
	}
	安土重山堡: {
		DisplayName: 安土重山堡
		Tooltip: 八转土道仙蛊屋，防御强大，是方源的重要据点。
	}
	乾清一气: {
		DisplayName: 乾清一气
		Tooltip: 八面威风蛊的主材，被武碑发现大量。
	}
	宠心: {
		DisplayName: 宠心
		Tooltip: 九转运道仙材，从藏地中获得。
	}
	贼巢: {
		DisplayName: 贼巢
		Tooltip: 仙蛊屋，方源改良过的全新版本，拥有偷道杀招。
	}
	升天真传: {
		DisplayName: 升天真传
		Tooltip: 孔升天留下的八转传承，包含仙蛊和仙元，已被方源交易获得内容。
	}
	火雷真传: {
		DisplayName: 火雷真传
		Tooltip: 火雷神君留下的八转真传，包含炎道雷道传承。
	}
	天难真传: {
		DisplayName: 天难真传
		Tooltip: 天难老怪留下的炼道真传，被宋家获得并视为核心传承。
	}
	九子龙图: {
		DisplayName: 九子龙图
		Tooltip: 商燕飞早年获得的仙缘，九张兽皮，每张描绘一种龙兽，有墨文注释，蕴含秘密。
	}
	人海雏形: {
		DisplayName: 人海雏形
		Tooltip: 人造天地秘境雏形，源自东海夏家，方源用于人道修行，需屠戮大量人族完善。
	}
	黑金铠甲: {
		DisplayName: 黑金铠甲
		Tooltip: 黑月仙子身穿的铠甲，给人沉重压迫感。
	}
	令牌信物: {
		DisplayName: 令牌信物
		Tooltip: 陈诚与友人的赌约信物，被黑月仙子出示。
	}
	事实浮冰: {
		DisplayName: 事实浮冰
		Tooltip: 无极魔尊用衍化仙蛊和天外混沌推演出的物品，蕴藏衍化仙蛊和天机蛊仙蛊方。
	}
	搬拦亭: {
		DisplayName: 搬拦亭
		Tooltip: 七转力道仙蛊屋，形如鸟笼，八根蓝金大柱弯曲。苏家所有，用于深海开采。
	}
	肝命仙蛊屋: {
		DisplayName: 肝命仙蛊屋
		Tooltip: 原为肝命大阵，后被方源改良为仙蛊屋，具有治疗和恢复功效。
	}
	贡献榜: {
		DisplayName: 贡献榜
		Tooltip: 至尊仙窍中的三大榜单之一，记录蛊仙贡献值，排名前列者为重臣。
	}
	任务榜: {
		DisplayName: 任务榜
		Tooltip: 至尊仙窍中的三大榜单之一，列出各种任务供蛊仙接取以获取贡献。
	}
	兑换榜: {
		DisplayName: 兑换榜
		Tooltip: 至尊仙窍中的三大榜单之一，列出可用贡献兑换的修行资源，极其丰富。
	}
	万岁楼: {
		DisplayName: 万岁楼
		Tooltip: 万家的仙蛊屋，随万家蛊仙一同撤走。
	}
	夜壶: {
		DisplayName: 夜壶
		Tooltip: 萧夜壶手中的暗道仙蛊屋，袖珍，能将蛊仙强行摄入其中，困上一夜化为一滩屎尿。
	}
	飞沙地洞: {
		DisplayName: 飞沙地洞
		Tooltip: 土道资源点，被移至至尊仙窍中作为地脉节点之一。
	}
	光明华轮火: {
		DisplayName: 光明华轮火
		Tooltip: 天下三火之一的天火，九转炎道仙材，太阳崩解后大量散落。
	}
	送生庙: {
		DisplayName: 送生庙
		Tooltip: 人道仙蛊屋，能快速让女子怀孕生子并附生蛊虫。
	}
	漂游炼巢: {
		DisplayName: 漂游炼巢
		Tooltip: 天地秘境雏形，状如蜂巢，漂浮炼海上，用于炼蛊。
	}
	市井: {
		DisplayName: 市井
		Tooltip: 天地秘境，方源用于天网恢恢杀招的防御核心。
	}
	心境: {
		DisplayName: 心境
		Tooltip: 天地秘境，星宿仙尊持有，灯笼形态，可抽取情绪和智道道痕。
	}
	血海雏形: {
		DisplayName: 血海雏形
		Tooltip: 巨阳仙尊拥有的天地秘境雏形，未发展完整。
	}
	乾坤晶壁雏形: {
		DisplayName: 乾坤晶壁雏形
		Tooltip: 天地秘境之一，书道阁收藏的一部分，信道底蕴。
	}
	气功果核: {
		DisplayName: 气功果核
		Tooltip: 天庭的气道造物，极为巨大，成为致命弱点。后被气海老祖炼化缩小，最终被方源用于炼成气道分身。
	}
