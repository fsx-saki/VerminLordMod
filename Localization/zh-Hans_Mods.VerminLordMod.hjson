	}

	StrengthLongicornbuff: {
		Description: 蛮力天牛蛊正赋予你强大的力量
		DisplayName: 天牛蛮力
	}

	Minilightbuff: {
		Description: 小光蛊正在加持月光蛊
		DisplayName: 小光蛊
	}

	FlowerPigbuff: {
		Description: 花豕蛊正赋予你一猪之力
		DisplayName: 花豕力
	}

	MoonLuminousTextilebuff: {
		DisplayName: 月华霓裳曲
		Description: 月光将吸收一部分伤害
	}

	GrassPuppetbuff: {
		DisplayName: 草傀
		Description: 那么，代价是什么呢？
	}

	BlackHairbuff: {
		DisplayName: 青丝
